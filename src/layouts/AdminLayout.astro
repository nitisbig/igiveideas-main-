---
import { resolveTheme } from '../lib/theme';
import { readSettings } from '../lib/auth';

/**
 * Shared chrome for the admin area. Kept intentionally plain — same paper/ink
 * palette as the public site, but its own compact layout. `showNav` is off on
 * the login page. Theme/font follow the saved admin settings so the panel
 * previews what visitors see.
 */
interface Props {
	title: string;
	showNav?: boolean;
	active?: string;
}
const { title, showNav = true, active = '' } = Astro.props;

const settings = await readSettings();
const { css, fontHref, fontFamily } = resolveTheme(settings?.theme, settings?.font);

const nav = [
	{ label: 'Dashboard', href: '/admin', key: 'home' },
	{ label: 'Emails', href: '/admin/emails', key: 'emails' },
	{ label: 'Ideas', href: '/admin/ideas', key: 'ideas' },
	{ label: 'Settings', href: '/admin/settings', key: 'settings' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} — igiveideas admin</title>
		{fontHref && <link href={fontHref} rel="stylesheet" />}
		<style set:html={`:root{${css}}body{font-family:${fontFamily};}`} />
	</head>
	<body>
		<div class="wrap">
			<header>
				<a class="brand" href="/admin">igiveideas · admin</a>
				{
					showNav && (
						<nav>
							{nav.map((item) => (
								<a href={item.href} aria-current={active === item.key ? 'page' : undefined}>
									{item.label}
								</a>
							))}
							<form method="POST" action="/api/admin/logout" class="logout">
								<button type="submit">Log out</button>
							</form>
						</nav>
					)
				}
			</header>
			<main>
				<slot />
			</main>
		</div>
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}
	:global(html),
	:global(body) {
		margin: 0;
		padding: 0;
	}
	:global(body) {
		background: var(--paper);
		color: var(--ink);
		font-size: 18px;
		line-height: 1.55;
		min-height: 100vh;
	}
	.wrap {
		max-width: 900px;
		margin: 0 auto;
		padding: 28px 24px 64px;
	}
	header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 12px;
		border-bottom: 2px solid var(--line);
		padding-bottom: 14px;
		margin-bottom: 28px;
	}
	.brand {
		color: var(--ink);
		text-decoration: none;
		font-size: 1.2rem;
		font-weight: 600;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 18px;
		flex-wrap: wrap;
	}
	nav a {
		color: var(--ink);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		padding-bottom: 2px;
	}
	nav a:hover {
		color: var(--accent);
	}
	nav a[aria-current='page'] {
		border-bottom-color: var(--ink);
	}
	.logout {
		margin: 0;
	}
	.logout button {
		background: transparent;
		border: 2px solid var(--line);
		border-radius: 8px;
		padding: 4px 12px;
		font: inherit;
		font-size: 0.85rem;
		color: var(--ink);
		cursor: pointer;
	}
	.logout button:hover {
		background: var(--ink);
		color: var(--paper);
	}
</style>
