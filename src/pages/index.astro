---
import Layout from '../layouts/Layout.astro';

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'igiveideas',
	url: 'https://igiveideas.com',
	description:
		'Branding needs taste, psychology and human connection. Learn how to add taste to your AI output.',
};
---

<Layout
	title="igiveideas — add taste to AI output"
	description="Do you know why the big AI labs are wrong about branding? Because AI output is tasteless. Branding needs taste, psychology and human connection. Learn how to run business like Leonardo da Vinci."
	path="/"
>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

	<article class="hero">
		<img
			class="portrait"
			src="/leonardo.svg"
			width="240"
			height="240"
			alt="Line drawing of Leonardo da Vinci"
		/>
		<h1>How to run business like Leonardo da Vinci?</h1>

		<p class="lede">
			Do you know why the anthropic, openai and google are wrong about AI? Because the output from
			AI is <em>tasteless</em>. Branding needs taste, psychology, human connection.
		</p>

		<p class="teach">i am teaching you how to add taste to the AI output.</p>

		<form id="idea-form" class="idea" novalidate>
			<!-- Step 1: the idea -->
			<div class="step" data-step="idea">
				<label for="idea">Write anything here <span>[ideas, website, problem]</span>:</label>
				<div class="row">
					<input
						id="idea"
						name="idea"
						type="text"
						autocomplete="off"
						required
						placeholder=""
					/>
					<button type="submit">Submit</button>
				</div>
			</div>

			<!-- Step 2: the email -->
			<div class="step" data-step="email" hidden>
				<p class="wow">wow that's great!</p>
				<label for="email">Where should the magic land? <span>[your email]</span>:</label>
				<div class="row">
					<input
						id="email"
						name="email"
						type="email"
						autocomplete="email"
						required
						placeholder="you@example.com"
					/>
					<button type="submit">Send</button>
				</div>
				<p class="error" data-step="error" role="alert" hidden></p>
			</div>

			<!-- Step 3: success -->
			<p class="step done" data-step="done" hidden>
				✦ i just sent a gift to you — check it out in your inbox!
			</p>
		</form>
	</article>
</Layout>

<script>
	const form = document.getElementById('idea-form') as HTMLFormElement | null;
	if (form) {
		const steps = {
			idea: form.querySelector('[data-step="idea"]') as HTMLElement,
			email: form.querySelector('[data-step="email"]') as HTMLElement,
			done: form.querySelector('[data-step="done"]') as HTMLElement,
		};
		const ideaInput = form.querySelector('#idea') as HTMLInputElement;
		const emailInput = form.querySelector('#email') as HTMLInputElement;
		const errorEl = form.querySelector('[data-step="error"]') as HTMLElement;
		const emailButton = steps.email.querySelector('button') as HTMLButtonElement;

		const show = (el: HTMLElement) => el.removeAttribute('hidden');
		const hide = (el: HTMLElement) => el.setAttribute('hidden', '');

		const showError = (message: string) => {
			errorEl.textContent = message;
			show(errorEl);
		};

		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			// Step 1 -> 2: acknowledge the idea, ask for the email.
			if (!steps.idea.hasAttribute('hidden')) {
				if (!ideaInput.value.trim()) {
					ideaInput.reportValidity();
					return;
				}
				hide(steps.idea);
				show(steps.email);
				emailInput.focus();
				return;
			}

			// Step 2 -> 3: send the email via the server, then show the gift message.
			if (!steps.email.hasAttribute('hidden')) {
				if (!emailInput.checkValidity()) {
					emailInput.reportValidity();
					return;
				}

				hide(errorEl);
				emailButton.disabled = true;
				const original = emailButton.textContent;
				emailButton.textContent = 'Sending…';

				try {
					const res = await fetch('/api/submit', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							idea: ideaInput.value.trim(),
							email: emailInput.value.trim(),
						}),
					});

					if (!res.ok) {
						const data = await res.json().catch(() => ({}));
						throw new Error(data.error || 'Something went wrong. Please try again.');
					}

					hide(steps.email);
					show(steps.done);
				} catch (err) {
					showError(err instanceof Error ? err.message : 'Something went wrong.');
					emailButton.disabled = false;
					emailButton.textContent = original;
				}
			}
		});
	}
</script>

<style>
	.hero {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding-top: clamp(8px, 3vw, 24px);
	}

	.portrait {
		width: clamp(160px, 30vw, 240px);
		height: auto;
	}

	h1 {
		font-weight: 500;
		font-size: clamp(1.4rem, 3.5vw, 2rem);
		margin: 18px 0 0;
	}

	.lede,
	.teach {
		max-width: 60ch;
		text-align: left;
		align-self: center;
		width: 100%;
	}

	.lede {
		margin-top: 36px;
		font-size: 1.1rem;
	}

	.teach {
		margin-top: 22px;
		font-family: 'Caveat', cursive;
		font-size: 1.5rem;
		color: var(--accent);
	}

	.idea {
		width: 100%;
		max-width: 60ch;
		align-self: center;
		text-align: left;
		margin-top: 4px;
	}

	label {
		display: block;
		margin-bottom: 10px;
	}

	label span {
		color: var(--ink-soft);
	}

	.row {
		display: flex;
		gap: 12px;
		align-items: center;
		flex-wrap: wrap;
	}

	input {
		flex: 1;
		min-width: 200px;
		background: transparent;
		border: none;
		border-bottom: 2px solid var(--line);
		border-radius: 6px 6px 0 0;
		padding: 8px 6px;
		font-family: inherit;
		font-size: 1rem;
		color: var(--ink);
	}

	input:focus {
		outline: none;
		border-bottom-color: var(--accent);
		background: rgba(138, 90, 43, 0.06);
	}

	button {
		background: transparent;
		border: 2px solid var(--line);
		border-radius: 10px;
		padding: 8px 22px;
		font-family: inherit;
		font-size: 1rem;
		color: var(--ink);
		cursor: pointer;
		transition: background 0.2s ease, color 0.2s ease;
	}

	button:hover {
		background: var(--ink);
		color: var(--paper);
	}

	.done {
		font-family: 'Caveat', cursive;
		font-size: 1.7rem;
		color: var(--accent);
		margin: 8px 0 0;
	}

	.wow {
		font-family: 'Caveat', cursive;
		font-size: 1.7rem;
		color: var(--accent);
		margin: 0 0 10px;
	}

	.error {
		color: #a3341f;
		font-size: 0.95rem;
		margin: 10px 0 0;
	}

	button:disabled {
		opacity: 0.55;
		cursor: default;
	}

	button:disabled:hover {
		background: transparent;
		color: var(--ink);
	}
</style>
