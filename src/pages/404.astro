---
import Layout from '../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="Page not found — igiveideas" description="The page you were looking for doesn't exist." path="/404">
	<section class="page">
		<h1>404</h1>
		<p class="lede">This page wandered off. Let's get you back to something useful.</p>
		<ul class="links">
			<li><a href="/">Home</a></li>
			<li><a href="/ideas">Ideas</a></li>
			<li><a href="/projects">Projects</a></li>
			<li><a href="/about">About</a></li>
		</ul>
	</section>
</Layout>

<style>
	.page {
		flex: 1;
		width: 100%;
		max-width: 60ch;
		margin: 0 auto;
		text-align: center;
		padding-top: clamp(40px, 10vw, 100px);
	}
	h1 {
		font-weight: 500;
		font-size: clamp(3rem, 12vw, 6rem);
		margin: 0;
	}
	.lede {
		margin: 12px 0 32px;
		font-size: 1.15rem;
		color: var(--ink-soft);
	}
	.links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: clamp(16px, 4vw, 32px);
	}
	.links a {
		color: var(--ink);
		text-decoration: none;
		font-size: 1.1rem;
		border-bottom: 2px solid transparent;
		transition: border-color 0.2s ease, color 0.2s ease;
	}
	.links a:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
</style>
