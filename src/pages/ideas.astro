---
import Layout from '../layouts/Layout.astro';

const ideas = [
	{
		title: 'Taste is the last moat',
		body: 'When everyone can generate a thousand variations in a second, the only scarce thing left is knowing which one is good. That judgement is taste.',
	},
	{
		title: 'Psychology before pixels',
		body: 'A brand is a promise a mind makes to itself. Design the feeling first; the colours and type are just how you keep the promise.',
	},
	{
		title: 'Human connection scales slowly — on purpose',
		body: 'The parts of a business that feel handmade are the parts people remember. Automate the boring, hand-finish the meaningful.',
	},
	{
		title: 'Run it like a workshop, not a factory',
		body: 'Leonardo ran a bottega: apprentices, experiments, unfinished masterpieces. Treat AI as your apprentice, not your replacement.',
	},
];
---

<Layout
	title="Ideas — igiveideas"
	description="Short essays on taste, psychology and human connection — and how to add all three to tasteless AI output."
	path="/ideas"
>
	<section class="page">
		<h1>Ideas</h1>
		<p class="intro">
			Notes on adding taste to the machine. Branding needs psychology and human connection — here is
			where I think out loud about both.
		</p>

		<ul class="cards">
			{
				ideas.map((idea) => (
					<li>
						<h2>{idea.title}</h2>
						<p>{idea.body}</p>
					</li>
				))
			}
		</ul>
	</section>
</Layout>

<style>
	.page {
		max-width: 70ch;
		margin: 0 auto;
	}

	h1 {
		font-weight: 500;
		font-size: clamp(1.8rem, 5vw, 2.6rem);
		margin: 8px 0 0;
	}

	.intro {
		color: var(--ink-soft);
		font-size: 1.15rem;
		margin-top: 12px;
	}

	.cards {
		list-style: none;
		padding: 0;
		margin: 32px 0 0;
		display: grid;
		gap: 22px;
	}

	.cards li {
		border: 2px solid var(--line);
		border-radius: 16px;
		padding: 22px 24px;
	}

	.cards h2 {
		margin: 0 0 8px;
		font-weight: 500;
		font-size: 1.4rem;
	}

	.cards p {
		margin: 0;
		color: var(--ink-soft);
	}
</style>
