---
import Layout from '../layouts/Layout.astro';
import { sbFetch } from '../lib/supabase';

export const prerender = false;

type Idea = { title: string; slug: string };

let ideas: Idea[] = [];
try {
	ideas = await sbFetch<Idea[]>('ideas', {
		query: '?select=title,slug&published=eq.true&order=sort_order.asc',
	});
} catch (err) {
	console.error('load public ideas failed:', err);
}
---

<Layout
	title="Ideas — igiveideas"
	description="Short notes on making machines work for you, converting ideas into code, and fixing the token."
	path="/ideas"
>
	<section class="page">
		<ul class="ideas">
			{
				ideas.map((idea) => (
					<li>
						<span class="hash">#</span>
						<a class="text" href={`/ideas/${idea.slug}`}>{idea.title}</a>
					</li>
				))
			}
			{ideas.length === 0 && <li class="empty">No ideas published yet.</li>}
		</ul>
	</section>
</Layout>

<style>
	.page {
		flex: 1;
		width: 100%;
		max-width: 70ch;
		margin: 0 auto;
		padding-top: clamp(24px, 5vw, 56px);
	}

	.ideas {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: clamp(20px, 3vw, 30px);
	}

	.ideas li {
		display: flex;
		gap: 12px;
		align-items: baseline;
		font-size: clamp(1.1rem, 2.4vw, 1.4rem);
	}

	.hash {
		color: var(--accent);
	}

	.text {
		color: var(--ink);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: border-color 0.2s ease, color 0.2s ease;
	}

	.text:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	.empty {
		color: var(--ink-soft);
		font-style: italic;
	}
</style>

