---
import Layout from '../layouts/Layout.astro';

const ideas = [
	'How to make machine works for you',
	'How to convert ideas into code',
	"Let's fix the token",
	'',
];
---

<Layout
	title="Ideas — igiveideas"
	description="Short notes on making machines work for you, converting ideas into code, and fixing the token."
	path="/ideas"
>
	<section class="page">
		<ul class="ideas">
			{
				ideas.map((idea) => (
					<li>
						<span class="hash">#</span>
						{idea && <span class="text">{idea}</span>}
					</li>
				))
			}
		</ul>
	</section>
</Layout>

<style>
	.page {
		flex: 1;
		width: 100%;
		max-width: 70ch;
		margin: 0 auto;
		padding-top: clamp(24px, 5vw, 56px);
	}

	.ideas {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: clamp(20px, 3vw, 30px);
	}

	.ideas li {
		display: flex;
		gap: 12px;
		align-items: baseline;
		font-size: clamp(1.1rem, 2.4vw, 1.4rem);
	}

	.hash {
		color: var(--accent);
	}

	.text {
		color: var(--ink);
	}
</style>
