---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="About — igiveideas"
	description="Hi, I am nitesh. Have dream to solve the great, have skill to see the soul, have attitude to win."
	path="/about"
>
	<section class="page">
		<img
			class="portrait"
			src="/leonardo.svg"
			width="150"
			height="150"
			alt="Portrait of nitesh"
		/>

		<div class="intro">
			<p>Hi, I am nitesh.</p>
			<p>Have dream to solve the great</p>
			<p>Have skill to see the soul</p>
			<p>Have attitude to win</p>
		</div>

		<div class="connect">
			<p class="label">Connect me:</p>
			<form class="connect-form">
				<label class="sr-only" for="connect">Connect with me</label>
				<input id="connect" name="connect" type="text" autocomplete="off" />
			</form>
		</div>
	</section>
</Layout>

<style>
	.page {
		flex: 1;
		width: 100%;
		max-width: 80ch;
		margin: 0 auto;
		position: relative;
		display: flex;
		flex-direction: column;
	}

	.portrait {
		position: absolute;
		top: 0;
		right: 0;
		width: clamp(96px, 16vw, 150px);
		height: auto;
	}

	.intro {
		margin-top: clamp(40px, 8vw, 90px);
		font-size: clamp(1.05rem, 2.4vw, 1.3rem);
		line-height: 1.5;
	}

	.intro p {
		margin: 0;
	}

	.connect {
		margin-top: auto;
		padding-top: clamp(40px, 8vw, 80px);
	}

	.label {
		text-align: center;
		margin: 0 0 18px;
		font-size: 1.1rem;
	}

	.connect-form {
		width: 100%;
	}

	input {
		width: 100%;
		background: transparent;
		border: 2px solid var(--line);
		border-radius: 14px;
		padding: 16px 20px;
		font-family: inherit;
		font-size: 1rem;
		color: var(--ink);
	}

	input:focus {
		outline: none;
		border-color: var(--accent);
		background: rgba(138, 90, 43, 0.06);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
