---
import Layout from '../layouts/Layout.astro';

// Rendered on demand so the admin-configured theme/font applies live.
export const prerender = false;

const links = [
	{
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/menitesh/',
		handle: 'in/menitesh',
	},
	{
		label: 'GitHub',
		href: 'https://github.com/nitisbig',
		handle: '@nitisbig',
	},
];

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'nitesh',
	url: 'https://igiveideas.com/about',
	description:
		'I write ideas, build in the open, and add taste to AI output — branding grounded in psychology and human connection.',
	sameAs: links.map((l) => l.href),
};
---

<Layout
	title="About — igiveideas"
	description="Hi, I am nitesh. I have a dream to solve the great, the skill to see the soul, and the attitude to win. Connect with me on LinkedIn and GitHub."
	path="/about"
>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
	<section class="page">
		<img
			class="portrait"
			src="/leonardo.svg"
			width="150"
			height="150"
			alt="Portrait of nitesh"
		/>

		<div class="intro">
			<p>Hi, I am <strong>nitesh</strong>.</p>
			<p>I have a dream to solve the great,</p>
			<p>the skill to see the soul,</p>
			<p>and the attitude to win.</p>
		</div>

		<p class="lede">
			I write ideas, build in the open, and add taste to AI output —
			branding grounded in psychology and human connection.
		</p>

		<div class="connect">
			<p class="label">Connect with me</p>
			<ul class="links">
				{
					links.map(({ label, href, handle }) => (
						<li>
							<a class="link" href={href} target="_blank" rel="noopener noreferrer" aria-label={label}>
								{label === 'LinkedIn' ? (
									<svg class="icon" viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
										<path
											fill="currentColor"
											d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.73V1.73C24 .77 23.21 0 22.23 0Z"
										/>
									</svg>
								) : (
									<svg class="icon" viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
										<path
											fill="currentColor"
											d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.28 5.69.42.36.79 1.06.79 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"
										/>
									</svg>
								)}
								<span class="link-text">
									<span class="link-label">{label}</span>
									<span class="link-handle">{handle}</span>
								</span>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</section>
</Layout>

<style>
	.page {
		flex: 1;
		width: 100%;
		max-width: 80ch;
		margin: 0 auto;
		position: relative;
		display: flex;
		flex-direction: column;
	}

	.portrait {
		position: absolute;
		top: 0;
		right: 0;
		width: clamp(96px, 16vw, 150px);
		height: auto;
	}

	.intro {
		margin-top: clamp(40px, 8vw, 90px);
		font-size: clamp(1.05rem, 2.4vw, 1.3rem);
		line-height: 1.5;
	}

	.intro p {
		margin: 0;
	}

	.lede {
		margin: 26px 0 0;
		max-width: 60ch;
		color: var(--ink-soft);
		font-size: 1.1rem;
		line-height: 1.6;
	}

	.connect {
		margin-top: auto;
		padding-top: clamp(40px, 8vw, 80px);
	}

	.label {
		text-align: center;
		margin: 0 0 18px;
		font-size: 1.1rem;
	}

	.links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: clamp(16px, 3vw, 26px);
	}

	.link {
		display: flex;
		align-items: center;
		gap: 12px;
		border: 2px solid var(--line);
		border-radius: 14px;
		padding: 14px 22px;
		color: var(--ink);
		text-decoration: none;
		transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
	}

	.link:hover,
	.link:focus-visible {
		color: var(--accent);
		border-color: var(--accent);
		background: rgba(138, 90, 43, 0.06);
		outline: none;
	}

	.icon {
		flex: 0 0 auto;
	}

	.link-text {
		display: flex;
		flex-direction: column;
		line-height: 1.2;
	}

	.link-label {
		font-size: 1.05rem;
	}

	.link-handle {
		font-size: 0.8rem;
		color: var(--ink-soft);
	}

	.link:hover .link-handle,
	.link:focus-visible .link-handle {
		color: inherit;
	}

	@media (max-width: 480px) {
		.links {
			flex-direction: column;
			align-items: stretch;
		}
		.link {
			justify-content: center;
		}
	}
</style>
