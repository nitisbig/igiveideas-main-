---
import Layout from '../layouts/Layout.astro';

// Rendered on demand so the admin-configured theme/font applies live.
export const prerender = false;

/**
 * Tech badge palette. Each key is a tech tag used in a project's `tech` list;
 * `label` is the monogram shown on the tile and `bg` its brand colour. Rendered
 * as inline SVG-free tiles so the page makes zero extra network requests
 * (keeps the "classic raw theme, loads fast" goal). Add a tech by adding a key.
 */
const TECH: Record<string, { label: string; bg: string; name: string }> = {
	typescript: { label: 'TS', bg: '#3178c6', name: 'TypeScript' },
	javascript: { label: 'JS', bg: '#f7df1e', name: 'JavaScript' },
	python: { label: 'PY', bg: '#3776ab', name: 'Python' },
	rust: { label: 'RS', bg: '#dea584', name: 'Rust' },
	go: { label: 'GO', bg: '#00add8', name: 'Go' },
	node: { label: 'N', bg: '#3c873a', name: 'Node.js' },
	react: { label: 'R', bg: '#61dafb', name: 'React' },
	astro: { label: 'A', bg: '#ff5d01', name: 'Astro' },
	bash: { label: 'SH', bg: '#4eaa25', name: 'Bash' },
};

/** Light labels (yellow/cyan) need dark text for contrast. */
const LIGHT_BG = new Set(['javascript', 'react']);

type Project = {
	/** Short handle shown as the card title. */
	name: string;
	/** Tech tags — keys of TECH above. First one drives the primary badge. */
	tech: string[];
	/** Copywriting lines, one per <span>. */
	body: string[];
	/** Exact GitHub repo URL. */
	github: string;
};

// Curated manifest. To add a project, append an entry (edit this list by hand).
const projects: Project[] = [
	{
		name: 'email-scraper',
		tech: ['typescript', 'node'],
		body: ['Find your first customer online.', 'Organic lead generation, for free.'],
		github: 'https://github.com/nitisbig/email-scraper',
	},
];
---

<Layout
	title="Projects — igiveideas"
	description="Open source tools that will save you 100000$ and 5 years. Find your first customer online with organic, free lead generation."
	path="/projects"
>
	<section class="page">
		<a class="gh-corner" href="https://github.com/nitisbig" aria-label="GitHub profile">
			<svg viewBox="0 0 24 24" width="30" height="30" aria-hidden="true">
				<path
					fill="currentColor"
					d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.28 5.69.42.36.79 1.06.79 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"
				></path>
			</svg>
			<span>GitHub</span>
		</a>

		<h1>World will be ruled by open source...</h1>
		<p class="sub">These tools will save you 100000$ and 5 years.</p>

		<ul class="cards">
			{
				projects.map((project) => (
					<li class="card">
						<div class="ident">
							<span class="name">{project.name}</span>
							<div class="badges">
								{project.tech
									.filter((t) => TECH[t])
									.map((t) => (
										<span class="badge" title={TECH[t].name}>
											<span
												class="tile"
												style={`background:${TECH[t].bg};color:${LIGHT_BG.has(t) ? '#1a1a1a' : '#fff'}`}
											>
												{TECH[t].label}
											</span>
											<span class="tname">{TECH[t].name}</span>
										</span>
									))}
							</div>
						</div>

						<div class="body">
							{project.body.map((line) => (
								<span>{line}</span>
							))}
						</div>

						<div class="actions">
							<a
								class="action"
								href={project.github}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={`${project.name} on GitHub`}
							>
								<svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
									<path
										fill="currentColor"
										d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.28 5.69.42.36.79 1.06.79 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"
									/>
								</svg>
								<span>Link</span>
							</a>
						</div>
					</li>
				))
			}
			{projects.length === 0 && <li class="empty">No projects yet.</li>}
		</ul>
	</section>
</Layout>

<style>
	.page {
		flex: 1;
		width: 100%;
		max-width: 80ch;
		margin: 0 auto;
		position: relative;
	}

	.gh-corner {
		position: absolute;
		top: 0;
		right: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		color: var(--ink);
		text-decoration: none;
		font-size: 0.8rem;
	}

	.gh-corner:hover {
		color: var(--accent);
	}

	h1 {
		font-weight: 600;
		font-size: clamp(1.4rem, 3.4vw, 2rem);
		margin: 8px 0 0;
		max-width: 26ch;
	}

	.sub {
		margin: 10px 0 0;
		font-size: 1.1rem;
		color: var(--ink-soft);
	}

	.cards {
		list-style: none;
		padding: 0;
		margin: 30px 0 0;
		display: grid;
		gap: 22px;
	}

	.card {
		display: flex;
		align-items: center;
		gap: clamp(16px, 3vw, 30px);
		border: 2px solid var(--line);
		border-radius: 16px;
		padding: 16px 22px;
	}

	.ident {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		flex: 0 0 auto;
	}

	.name {
		font-family: 'Caveat', cursive;
		font-size: 1.7rem;
		line-height: 1.1;
		text-align: center;
	}

	.badges {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 8px;
	}

	.badge {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
	}

	.tile {
		display: grid;
		place-items: center;
		width: 26px;
		height: 26px;
		font-family: 'Arial', sans-serif;
		font-weight: 700;
		font-size: 0.72rem;
		border-radius: 4px;
	}

	.tname {
		font-size: 0.6rem;
		color: var(--ink-soft);
	}

	.body {
		flex: 1;
		display: flex;
		flex-direction: column;
		line-height: 1.35;
	}

	.actions {
		display: flex;
		align-items: center;
		gap: clamp(10px, 2vw, 18px);
		flex: 0 0 auto;
	}

	.action {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		color: var(--ink);
		text-decoration: none;
		font-size: 0.7rem;
	}

	.action:hover {
		color: var(--accent);
	}

	.empty {
		list-style: none;
		text-align: center;
		color: var(--ink-soft);
		font-style: italic;
	}

	@media (max-width: 640px) {
		.card {
			flex-wrap: wrap;
			justify-content: center;
			text-align: center;
		}
		.body {
			flex-basis: 100%;
			align-items: center;
		}
	}
</style>
