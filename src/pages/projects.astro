---
import Layout from '../layouts/Layout.astro';

const projects = [
	{
		name: 'email-scraper',
		lang: 'TypeScript',
		body: ['find out your first costumer online', "it's organic, lead generation for free"],
		plus: '#',
		github: '#',
		demo: '#',
	},
	{
		name: 'email-scraper',
		lang: 'TypeScript',
		body: ['find out your first costumer online', "it's organic, lead generation for free"],
		plus: '#',
		github: '#',
		demo: '#',
	},
	{
		name: 'email-scraper',
		lang: 'TypeScript',
		body: ['find out your first costumer online', "it's organic, lead generation for free"],
		plus: '#',
		github: '#',
		demo: '#',
	},
];
---

<Layout
	title="Projects — igiveideas"
	description="Open source tools that will save you 100000$ and 5 years. Find your first customer online with organic, free lead generation."
	path="/projects"
>
	<section class="page">
		<a class="gh-corner" href="https://github.com" aria-label="GitHub">
			<svg viewBox="0 0 24 24" width="30" height="30" aria-hidden="true">
				<path
					fill="currentColor"
					d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.28 5.69.42.36.79 1.06.79 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"
				></path>
			</svg>
			<span>GitHub</span>
		</a>

		<h1>World will be rule by open source...</h1>
		<p class="sub">This tools will save you 100000$ and 5 years.</p>

		<ul class="cards">
			{
				projects.map((project) => (
					<li class="card">
						<div class="ident">
							<span class="name">{project.name}</span>
							<span class="badge">
								<span class="ts">TS</span>
								<span class="lang">{project.lang}</span>
							</span>
						</div>

						<div class="body">
							{project.body.map((line) => (
								<span>{line}</span>
							))}
						</div>

						<div class="actions">
							<a class="action" href={project.plus} aria-label="Add">
								<svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
									<circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5" />
									<path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
								</svg>
								<span>Plus</span>
							</a>
							<span class="divider" />
							<a class="action" href={project.github} aria-label="GitHub">
								<svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
									<path
										fill="currentColor"
										d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.28 5.69.42.36.79 1.06.79 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"
									/>
								</svg>
								<span>GitHub</span>
							</a>
							<span class="divider" />
							<a class="action" href={project.demo} aria-label="Demo">
								<svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
									<rect x="2.5" y="5" width="19" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.5" />
									<path d="M10 9.5v5l4-2.5-4-2.5Z" fill="currentColor" />
								</svg>
							</a>
						</div>
					</li>
				))
			}
		</ul>
	</section>
</Layout>

<style>
	.page {
		flex: 1;
		width: 100%;
		max-width: 80ch;
		margin: 0 auto;
		position: relative;
	}

	.gh-corner {
		position: absolute;
		top: 0;
		right: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		color: var(--ink);
		text-decoration: none;
		font-size: 0.8rem;
	}

	h1 {
		font-weight: 600;
		font-size: clamp(1.4rem, 3.4vw, 2rem);
		margin: 8px 0 0;
	}

	.sub {
		text-align: center;
		margin: 10px 0 0;
		font-size: 1.1rem;
	}

	.cards {
		list-style: none;
		padding: 0;
		margin: 30px 0 0;
		display: grid;
		gap: 22px;
	}

	.card {
		display: flex;
		align-items: center;
		gap: clamp(16px, 3vw, 30px);
		border: 2px solid var(--line);
		border-radius: 16px;
		padding: 16px 22px;
	}

	.ident {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		flex: 0 0 auto;
	}

	.name {
		font-family: 'Caveat', cursive;
		font-size: 1.7rem;
	}

	.badge {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3px;
	}

	.ts {
		display: grid;
		place-items: center;
		width: 26px;
		height: 26px;
		background: #3178c6;
		color: #fff;
		font-family: 'Arial', sans-serif;
		font-weight: 700;
		font-size: 0.8rem;
		border-radius: 4px;
	}

	.lang {
		font-size: 0.65rem;
		color: var(--ink-soft);
	}

	.body {
		flex: 1;
		display: flex;
		flex-direction: column;
		line-height: 1.35;
	}

	.actions {
		display: flex;
		align-items: center;
		gap: clamp(10px, 2vw, 18px);
		flex: 0 0 auto;
	}

	.action {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		color: var(--ink);
		text-decoration: none;
		font-size: 0.7rem;
	}

	.action:hover {
		color: var(--accent);
	}

	.divider {
		width: 2px;
		align-self: stretch;
		background: var(--line);
		opacity: 0.4;
	}

	@media (max-width: 640px) {
		.card {
			flex-wrap: wrap;
			justify-content: center;
			text-align: center;
		}
		.body {
			flex-basis: 100%;
			align-items: center;
		}
	}
</style>
