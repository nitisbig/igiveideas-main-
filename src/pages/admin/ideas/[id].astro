---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { sbFetch } from '../../../lib/supabase';

export const prerender = false;

const { id } = Astro.params;

type Idea = {
	id: string;
	title: string;
	slug: string;
	body: string;
	published: boolean;
	sort_order: number;
};

let idea: Idea | null = null;
try {
	const rows = await sbFetch<Idea[]>('ideas', {
		query: `?id=eq.${encodeURIComponent(id!)}&select=*&limit=1`,
	});
	idea = rows?.[0] ?? null;
} catch (err) {
	console.error('load idea failed:', err);
}

if (!idea) {
	return Astro.redirect('/admin/ideas?error=notfound');
}
---

<AdminLayout title="Edit idea" active="ideas">
	<p class="back"><a href="/admin/ideas">← Back to ideas</a></p>
	<h1>Edit idea</h1>

	<form method="POST" action="/api/admin/ideas" class="form">
		<input type="hidden" name="_action" value="update" />
		<input type="hidden" name="id" value={idea.id} />

		<label for="title">Title</label>
		<input id="title" name="title" type="text" required value={idea.title} />

		<p class="slug">Public URL: <code>/ideas/{idea.slug}</code> <span>(regenerated from the title on save)</span></p>

		<label for="body">Body</label>
		<textarea id="body" name="body" rows="12">{idea.body}</textarea>

		<div class="inline">
			<div>
				<label for="sort_order">Order</label>
				<input id="sort_order" name="sort_order" type="number" value={idea.sort_order} />
			</div>
			<label class="check">
				<input type="checkbox" name="published" checked={idea.published} />
				Published
			</label>
		</div>

		<button type="submit">Save changes</button>
	</form>
</AdminLayout>

<style>
	.back {
		margin: 0 0 8px;
	}
	.back a {
		color: var(--accent);
		text-decoration: none;
		font-size: 0.9rem;
	}
	h1 {
		font-weight: 600;
		margin: 0 0 18px;
	}
	.form {
		display: grid;
		gap: 8px;
		max-width: 680px;
	}
	label {
		font-size: 0.9rem;
		color: var(--ink-soft);
		margin-top: 6px;
	}
	input[type='text'],
	input[type='number'],
	textarea {
		background: transparent;
		border: 2px solid var(--line);
		border-radius: 8px;
		padding: 10px 12px;
		font: inherit;
		color: var(--ink);
		width: 100%;
	}
	textarea {
		resize: vertical;
	}
	input:focus,
	textarea:focus {
		outline: none;
		border-color: var(--accent);
	}
	.slug {
		font-size: 0.85rem;
		color: var(--ink-soft);
		margin: 6px 0 0;
	}
	.slug code {
		color: var(--ink);
	}
	.slug span {
		opacity: 0.8;
	}
	.inline {
		display: flex;
		align-items: flex-end;
		gap: 24px;
		flex-wrap: wrap;
	}
	.inline input[type='number'] {
		width: 100px;
	}
	.check {
		display: flex;
		align-items: center;
		gap: 8px;
		color: var(--ink);
		margin-top: 6px;
	}
	.check input {
		width: auto;
	}
	button[type='submit'] {
		margin-top: 16px;
		justify-self: start;
		background: transparent;
		border: 2px solid var(--line);
		border-radius: 10px;
		padding: 10px 22px;
		font: inherit;
		color: var(--ink);
		cursor: pointer;
	}
	button[type='submit']:hover {
		background: var(--ink);
		color: var(--paper);
	}
</style>
