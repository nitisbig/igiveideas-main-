---
export const prerender = false;

/**
 * Legacy edit route. The article editor now lives at `/admin/ideas/write?id=…`.
 * Anything still pointing here (old bookmarks, links) is forwarded there.
 */
const { id } = Astro.params;
return Astro.redirect(`/admin/ideas/write?id=${encodeURIComponent(id!)}`);
