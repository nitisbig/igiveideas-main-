---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { sbFetch } from '../../lib/supabase';

export const prerender = false;

type Idea = {
	id: string;
	title: string;
	slug: string;
	published: boolean;
	sort_order: number;
};

let ideas: Idea[] = [];
let failed = false;
try {
	ideas = await sbFetch<Idea[]>('ideas', {
		query: '?select=id,title,slug,published,sort_order&order=sort_order.asc',
	});
} catch (err) {
	console.error('load ideas failed:', err);
	failed = true;
}

const params = Astro.url.searchParams;
const ok = params.get('ok');
const error = params.get('error');
const notice =
	ok === 'created'
		? 'Idea created.'
		: ok === 'updated'
			? 'Idea updated.'
			: ok === 'deleted'
				? 'Idea deleted.'
				: '';
const problem =
	error === 'title'
		? 'A title is required.'
		: error
			? 'Something went wrong. Please try again.'
			: '';
---

<AdminLayout title="Ideas" active="ideas">
	<div class="head">
		<h1>Ideas</h1>
		<a class="write" href="/admin/ideas/write">✎ Write new article</a>
	</div>

	{notice && <p class="notice">{notice}</p>}
	{problem && <p class="error">{problem}</p>}
	{failed && <p class="error">Could not load ideas. Check the server logs.</p>}

	<section class="list">
		{ideas.length === 0 && !failed && <p class="empty">No ideas yet. Write your first article.</p>}
		{
			ideas.map((idea) => (
				<div class="row">
					<div class="meta">
						<span class="ord">#{idea.sort_order}</span>
						<a class="title" href={`/admin/ideas/write?id=${idea.id}`}>{idea.title}</a>
						{!idea.published && <span class="draft">draft</span>}
					</div>
					<div class="row-actions">
						<a class="edit" href={`/admin/ideas/write?id=${idea.id}`}>Edit</a>
						<form
							method="POST"
							action="/api/admin/ideas"
							onsubmit="return confirm('Delete this idea?')"
						>
							<input type="hidden" name="_action" value="delete" />
							<input type="hidden" name="id" value={idea.id} />
							<button type="submit" class="del">Delete</button>
						</form>
					</div>
				</div>
			))
		}
	</section>
</AdminLayout>

<style>
	.head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		flex-wrap: wrap;
		margin: 0 0 18px;
	}
	h1 {
		font-weight: 600;
		margin: 0;
	}
	.write {
		border: 2px solid var(--line);
		border-radius: 10px;
		padding: 8px 16px;
		font-size: 0.9rem;
		color: var(--ink);
		text-decoration: none;
	}
	.write:hover {
		background: var(--ink);
		color: var(--paper);
	}
	.list {
		display: grid;
		gap: 10px;
		margin-bottom: 40px;
	}
	.row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		border: 2px solid var(--line);
		border-radius: 12px;
		padding: 12px 16px;
	}
	.meta {
		display: flex;
		align-items: baseline;
		gap: 10px;
		min-width: 0;
	}
	.ord {
		color: var(--ink-soft);
		font-size: 0.85rem;
	}
	.title {
		color: var(--ink);
		text-decoration: none;
		font-weight: 500;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.title:hover {
		color: var(--accent);
	}
	.draft {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--ink-soft);
		border: 1px solid var(--ink-soft);
		border-radius: 6px;
		padding: 1px 6px;
	}
	.row-actions {
		display: flex;
		align-items: center;
		gap: 12px;
		flex: 0 0 auto;
	}
	.row-actions form {
		margin: 0;
	}
	.edit {
		color: var(--accent);
		text-decoration: none;
		font-size: 0.9rem;
	}
	.del {
		background: transparent;
		border: none;
		color: #a3341f;
		cursor: pointer;
		font: inherit;
		font-size: 0.9rem;
		padding: 0;
	}
	.del:hover {
		text-decoration: underline;
	}
	.notice {
		color: var(--accent);
	}
	.error {
		color: #a3341f;
	}
	.empty {
		color: var(--ink-soft);
	}
</style>
