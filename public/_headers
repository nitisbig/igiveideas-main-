# Cloudflare static-asset caching. The Astro Cloudflare adapter auto-appends
# an immutable rule for /_astro/* (content-hashed bundles). These rules cover
# the un-hashed files in public/ — safe to cache for a day with revalidation.

/og.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/leonardo.svg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/favicon.svg
  Cache-Control: public, max-age=86400

/favicon.ico
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400
